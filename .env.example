# Wedding RSVP — copy to .env and adjust

PG_HOST=localhost
PG_PORT=5432
PG_DB=wedding_rsvp
PG_USER=postgres
PG_PASS=

ENVIRONMENT=development
ENCRYPTION_KEY=

SESSION_TIMEOUT=3600
SESSION_SECURE_COOKIE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

PUBLIC_BASE_URL=http://localhost:3000

# Optional — Google Sheets export (service account JSON path)
# GOOGLE_SHEETS_ID=your-spreadsheet-id
# GOOGLE_SHEETS_CREDENTIALS_PATH=../credentials/google-sheets.json

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=../logs/audit.log
KEY_BACKUP_PATH=../keys/backup/

API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW=3600

# Optional dev-only guest password login (disabled for production guests)
# ENABLE_DEV_GUEST_BYPASS=false
# DEV_GUEST_INVITATION_ID=dev
# DEV_GUEST_PASSWORD=dev

# Reception venue app (/reception/)
# RECEPTION_API_KEY=your-secret-venue-key
# RECEPTION_UPLOAD_MAX_BYTES=5242880
# RECEPTION_UPLOAD_MAX_PER_HOUR=40
